# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=capstone_db
DB_USER=capstone_user
DB_PASSWORD=capstone123
MYSQL_ROOT_PASSWORD=root123

# Server Ports
FASTAPI_PORT=8000
NODEJS_PORT=5000
SPRINGBOOT_PORT=8080
DOTNET_PORT=7000
NGINX_PORT=80

# Environment
APP_ENV=production
NODE_ENV=production
ASPNETCORE_ENVIRONMENT=Production
JAVA_OPTS=-Xmx512m

# API Endpoints (for frontend)
FRONTEND_URL=http://localhost:5173
API_GATEWAY_URL=http://localhost:80

# JWT Secret (if needed later)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
